# Supabase (get values from https://supabase.com/dashboard/project/<ref>/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM provider routing (via Vercel AI Gateway)
# Default provider + models for each role (see lib/llm/config.ts in Task 22).
# Override these in .env.local to swap providers without touching code.
LLM_CONVERSATIONAL_PROVIDER=anthropic
LLM_CONVERSATIONAL_MODEL=claude-sonnet-4.6
LLM_FAST_PROVIDER=anthropic
LLM_FAST_MODEL=claude-haiku-4.5
LLM_STRUCTURED_PROVIDER=anthropic
LLM_STRUCTURED_MODEL=claude-sonnet-4.6

# VERCEL_OIDC_TOKEN is injected automatically by `vercel env pull .env.local --yes`.
# Used by @ai-sdk/gateway for authenticated routing. Refresh every ~24h during local dev.

# Plan 6 — Cross-session continuity. When set to 'on' the /api/chat endpoint injects
# a patientContextBlock + riskOpeningNotice into the system prompt based on the
# patient's last validated assessment, open risk events, and pending tasks.
# Off by default. Requires clinical sign-off on copy before enabling in production.
FEATURE_CROSS_SESSION_CONTEXT=off

# Plan 7 T6 — Vercel Cron auth secret for /api/internal/close-stale-sessions.
# Vercel sets `Authorization: Bearer ${CRON_SECRET}` automatically on production
# crons when this is configured at https://vercel.com/{team}/{project}/settings/environment-variables.
# Generate locally with: `openssl rand -base64 32`. The route refuses requests
# without a matching Bearer token — without this set, the cron silently no-ops
# in preview/local and abandoned sessions never reach the clinician inbox.
CRON_SECRET=
